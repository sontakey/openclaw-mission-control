# Mission Control Configuration
# Copy this file to .env and fill in your values

# Port for the Mission Control server
PORT=3100

# OpenClaw gateway URL (default: localhost on standard port)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# OpenClaw gateway auth token
# Find this in your OpenClaw config: gateway.auth.token
# Or check: grep GATEWAY_AUTH_TOKEN ~/.openclaw/.env
OPENCLAW_TOKEN=

# SQLite database file path (default: mission-control.db in project root)
DATABASE_FILE=mission-control.db
